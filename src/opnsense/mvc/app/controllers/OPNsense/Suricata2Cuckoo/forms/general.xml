<form>
  <field>
    <id>suricata2cuckoo.general.Enabled</id>
    <label>Enable Suricata2Cuckoo</label>
    <type>checkbox</type>
  </field>

  <field>
    <id>suricata2cuckoo.general.Protocols</id>
    <label>Protocols</label>
    <type>text</type>
    <size>70</size>
    <hint>e.g. http, smtp, ftp, smb</hint>
    <help>Comma- or space-separated Suricata protocol keywords used in generated file-extract rules. Case does not matter; Apply lowercases them. Click the field for a quick reference (popover).</help>
  </field>

  <field>
    <id>suricata2cuckoo.general.FileExtensions</id>
    <label>File extensions</label>
    <type>text</type>
    <help>Comma-separated list. You may type ".docx" or "docx". Example: doc,docx,pdf,zip,exe</help>
  </field>

  <field>
    <id>suricata2cuckoo.general.EnableEveSyslog</id>
    <label>Enable EVE syslog output</label>
    <type>checkbox</type>
  </field>
  <field>
    <id>suricata2cuckoo.general.EnableEveHttp</id>
    <label>Enable EVE HTTP logging</label>
    <type>checkbox</type>
  </field>
  <field>
    <id>suricata2cuckoo.general.EnableEveFiles</id>
    <label>Enable EVE fileinfo (files)</label>
    <type>checkbox</type>
    <help>Enables fileinfo events and forces magic/hash logging (md5 + sha256).</help>
  </field>
  <field>
    <id>suricata2cuckoo.general.EnableFileStore</id>
    <label>Enable file-store output</label>
    <type>checkbox</type>
  </field>

  <field>
    <id>suricata2cuckoo.general.FilestorePath</id>
    <label>Filestore path</label>
    <type>text</type>
  </field>
  <field>
    <id>suricata2cuckoo.general.WatchMethod</id>
    <label>Watch method</label>
    <type>text</type>
    <size>24</size>
    <hint>polling or kqueue</hint>
    <help>Type one method name. The daemon lowercases it: only <code>kqueue</code> selects kqueue; anything else uses polling. Focus the field for a short reference.</help>
  </field>
  <field>
    <id>suricata2cuckoo.general.PollInterval</id>
    <label>Polling interval (seconds)</label>
    <type>text</type>
  </field>
  <field>
    <id>suricata2cuckoo.general.FileSettleTime</id>
    <label>File settle time (seconds)</label>
    <type>text</type>
  </field>

  <field>
    <id>suricata2cuckoo.general.CuckooApiUrl</id>
    <label>Cuckoo Sandbox URL API</label>
    <type>text</type>
  </field>
  <field>
    <id>suricata2cuckoo.general.CuckooApiToken</id>
    <label>Cuckoo Sandbox API Token</label>
    <type>password</type>
    <help>Optional. Stored in config.xml; not shown in logs.</help>
  </field>
  <field>
    <id>suricata2cuckoo.general.CuckooGuest</id>
    <label>Cuckoo Sandbox Guest VM</label>
    <type>text</type>
  </field>
</form>

