<model>
  <mount>//OPNsense/suricata2cuckoo</mount>
  <description>Suricata2Cuckoo integration settings</description>
  <items>
    <general>
      <Enabled type="BooleanField">
        <Default>0</Default>
        <Required>Y</Required>
      </Enabled>

      <!-- Comma or space separated Suricata app-layer keywords, e.g. http, smtp, ftp, smb -->
      <Protocols type="TextField">
        <Default>http</Default>
        <Required>Y</Required>
      </Protocols>

      <!-- Comma separated list, without dots: docx,pdf,exe,zip -->
      <FileExtensions type="TextField">
        <Default>doc,docx,pdf,zip,exe</Default>
        <Required>Y</Required>
      </FileExtensions>

      <!-- IDS prerequisites we will enforce on Apply -->
      <EnableEveSyslog type="BooleanField">
        <Default>1</Default>
        <Required>Y</Required>
      </EnableEveSyslog>
      <EnableEveHttp type="BooleanField">
        <Default>1</Default>
        <Required>Y</Required>
      </EnableEveHttp>
      <EnableEveFiles type="BooleanField">
        <Default>1</Default>
        <Required>Y</Required>
      </EnableEveFiles>
      <EnableFileStore type="BooleanField">
        <Default>1</Default>
        <Required>Y</Required>
      </EnableFileStore>

      <!-- suricata2cuckoo.conf -->
      <FilestorePath type="TextField">
        <Default>/var/log/suricata/filestore</Default>
        <Required>Y</Required>
      </FilestorePath>
      <WatchMethod type="OptionField">
        <Required>Y</Required>
        <Multiple>N</Multiple>
        <Default>polling</Default>
        <OptionValues>
          <polling>polling (works everywhere)</polling>
          <kqueue>kqueue (BSD; requires IO::KQueue Perl module)</kqueue>
        </OptionValues>
      </WatchMethod>
      <PollInterval type="IntegerField">
        <Default>5</Default>
        <MinimumValue>1</MinimumValue>
        <MaximumValue>3600</MaximumValue>
        <Required>Y</Required>
      </PollInterval>
      <FileSettleTime type="IntegerField">
        <Default>2</Default>
        <MinimumValue>0</MinimumValue>
        <MaximumValue>3600</MaximumValue>
        <Required>Y</Required>
      </FileSettleTime>

      <CuckooApiUrl type="TextField">
        <Default>http://127.0.0.1:8090</Default>
        <Required>Y</Required>
      </CuckooApiUrl>
      <CuckooApiToken type="TextField">
        <Default></Default>
      </CuckooApiToken>
      <CuckooGuest type="TextField">
        <Default>Cuckoo1</Default>
        <Required>Y</Required>
      </CuckooGuest>
    </general>
  </items>
</model>

